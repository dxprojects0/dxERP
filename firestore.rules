rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdminEmail() {
      return isAuthenticated() && request.auth.token.email == 'admin@dxtoolz.com';
    }

    function selfRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data)
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data).data.role
            : null
        );
    }

    function isAdminRole() {
      return isAuthenticated() && selfRole() == 'admin';
    }

    function isPrivilegedAdmin() {
      return isAdminEmail() || isAdminRole();
    }

    function selfPlan() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan
        : (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data)
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data).data.plan
            : 'free'
        );
    }

    function isPaidOrAdmin() {
      return isPrivilegedAdmin() || selfPlan() == 'pro' || selfPlan() == 'business';
    }

    function isAllowedBucket(bucket) {
      return bucket == 'profile'
        || bucket == 'dashboard'
        || bucket == 'inventory'
        || bucket == 'tasks';
    }

    function isProfileDoc(bucket, docId) {
      return bucket == 'profile' && docId == 'data';
    }

    function isBucketDoc(docId) {
      return docId == 'data';
    }

    function isNewProfileDoc(userId) {
      return !exists(/databases/$(database)/documents/users/$(userId)/profile/data);
    }

    function hasProfile(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/profile/data);
    }

    function profileRoleIsSafe(userId, bucket, docId) {
      return isPrivilegedAdmin()
        || !isProfileDoc(bucket, docId)
        || !('role' in request.resource.data)
        || (
          isNewProfileDoc(userId)
            ? (
              request.resource.data.role == 'user'
              || (request.resource.data.role == 'admin' && isAdminEmail())
            )
            : (
              request.resource.data.role == resource.data.role
              || isAdminRole()
            )
        );
    }

    function profileUidIsSafe(userId, bucket, docId) {
      return isPrivilegedAdmin()
        || !isProfileDoc(bucket, docId)
        || !('uid' in request.resource.data)
        || request.resource.data.uid == userId;
    }

    function profileEmailIsSafe(bucket, docId) {
      return isPrivilegedAdmin()
        || !isProfileDoc(bucket, docId)
        || !('email' in request.resource.data)
        || request.resource.data.email == null
        || request.resource.data.email is string;
    }

    function profilePlanIsSafe(bucket, docId) {
      return isPrivilegedAdmin()
        || !isProfileDoc(bucket, docId)
        || !('plan' in request.resource.data)
        || (
          ('plan' in resource.data)
            ? (request.resource.data.plan == resource.data.plan || request.resource.data.plan == 'free')
            : request.resource.data.plan == 'free'
        );
    }

    function profileCategoryIsSafe(bucket, docId) {
      return isPrivilegedAdmin()
        || !isProfileDoc(bucket, docId)
        || !('selectedProfessionId' in request.resource.data)
        || request.resource.data.selectedProfessionId != 'admin';
    }

    function profilePlanApprovalIsSafe(bucket, docId) {
      return isPrivilegedAdmin()
        || !isProfileDoc(bucket, docId)
        || !('planApprovedByAdmin' in request.resource.data)
        || (
          ('planApprovedByAdmin' in resource.data)
            ? request.resource.data.planApprovedByAdmin == resource.data.planApprovedByAdmin
            : request.resource.data.planApprovedByAdmin == false
        );
    }

    // Legacy compatibility: allow read-only migration from old users/{uid} docs.
    match /users/{userId} {
      allow read: if isOwner(userId) || isPrivilegedAdmin();
      allow create: if isPrivilegedAdmin() || (
        isOwner(userId)
        && request.resource.data.uid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == 'user')
        && (!('plan' in request.resource.data) || request.resource.data.plan == 'free')
        && (
          !('planStatus' in request.resource.data)
          || request.resource.data.planStatus == 'active'
          || request.resource.data.planStatus == 'pending'
        )
      );
      allow update: if isPrivilegedAdmin() || (
        isOwner(userId)
        && request.resource.data.uid == userId
        && (
          !('role' in request.resource.data)
          || request.resource.data.role == resource.data.role
          || (!('role' in resource.data) && request.resource.data.role == 'user')
        )
        && (
          !('plan' in request.resource.data)
          || request.resource.data.plan == resource.data.plan
          || (!('plan' in resource.data) && request.resource.data.plan == 'free')
        )
        && (
          !('planStatus' in request.resource.data)
          || request.resource.data.planStatus == 'active'
          || request.resource.data.planStatus == 'pending'
        )
      );
      allow delete: if false;
    }

    match /users/{userId}/{bucket}/{docId} {
      allow read: if isAllowedBucket(bucket) && isBucketDoc(docId) && (isOwner(userId) || isPrivilegedAdmin());
      allow create, update: if isAllowedBucket(bucket)
        && isBucketDoc(docId)
        && (isOwner(userId) || isPrivilegedAdmin())
        && (isProfileDoc(bucket, docId) || isPaidOrAdmin())
        && (isProfileDoc(bucket, docId) || hasProfile(userId) || isPrivilegedAdmin())
        && profileRoleIsSafe(userId, bucket, docId)
        && profileUidIsSafe(userId, bucket, docId)
        && profileEmailIsSafe(bucket, docId)
        && profilePlanIsSafe(bucket, docId)
        && profileCategoryIsSafe(bucket, docId)
        && profilePlanApprovalIsSafe(bucket, docId);
      allow delete: if false;
    }

    match /adminAccounts/{adminId} {
      allow read, write: if isPrivilegedAdmin();
    }

    match /adminManagement/{docId} {
      allow read, write: if isPrivilegedAdmin();
    }

    match /marketingUsers/{code} {
      allow read: if true;
      allow create, update, delete: if isPrivilegedAdmin();
    }

    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isPrivilegedAdmin();
    }

    match /PaidInterests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.phoneNumber is string
        && request.resource.data.email is string
        && request.resource.data.businessName is string
        && request.resource.data.ownerName is string
        && (request.resource.data.requestedPlan == 'pro' || request.resource.data.requestedPlan == 'business_plus');
      allow read: if isPrivilegedAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow update, delete: if isPrivilegedAdmin();
    }
  }
}
